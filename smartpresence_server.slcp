# Silicon Labs Project Configuration Tools: slcp, v0, Component selection file.
project_name: smartpresence_server
label: smartpresence_server
description: This example demonstrates the Bluetooth Mesh Sensor Server Model and
  Sensor Setup Server Model. It measures temperature and sends the measurement data
  to a remote device (e.g., btmesh_soc_sensor_client).
category: Bluetooth Mesh Examples
filter:
- name: Device Type
  value:
  - SoC
- name: Project Difficulty
  value:
  - Advanced
- name: Wireless Technology
  value:
  - Bluetooth Mesh
package: bluetooth_mesh_app
quality: production
readme:
- path: readme.md
source:
- path: app.c
- path: app_bm.c
- path: app_out_log.c
- path: local_cli_commands.c
tag:
- hardware:component:button:2+
- hardware:component:led:2+
- prebuilt_demo
- hardware:rf:band:2400
- hwfilter:device:device_generic_family_efr32xg22
- hwfilter:flash:512k
- hardware:board_only
- hardware:device:sdid:!215
- hwfilter:board:simple_button:btn0
- hwfilter:board:simple_led:led1
- hwfilter:board:simple_button:btn1
- hwfilter:board:simple_led:led0
- hardware:component:sensor:si7021
- hwfilter:device:device_supports_bluetooth
- hwfilter:ram:32k
- hwfilter:!board:hardware:has:sensor:si1133
- hardware:device:sdid:205
- hwfilter:board:hardware_board_has_si70xx
- hardware:component:sensor:!si1133
- hardware:device:flash:512
- hwfilter:device:device_series_2
- hardware:device:ram:32
