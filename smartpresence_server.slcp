template_contribution:
- name: cli_command
  priority: 0
  value:
    name: info
    handler: info
    help: Prints info about BT address and mesh UUID
configuration:
- name: EMDRV_DMADRV_DMA_CH_COUNT
  value: '4'
- name: APP_LOG_LEVEL
  value: APP_LOG_LEVEL_INFO
- name: NVM3_DEFAULT_CACHE_SIZE
  value: '100'
- name: NVM3_DEFAULT_NVM_SIZE
  value: '0x6000'
- condition:
  - si70xx_driver
  - i2cspm
  name: SL_BOARD_ENABLE_SENSOR_RHT
  value: '1'
- condition:
  - iostream_usart
  name: SL_BOARD_ENABLE_VCOM
  value: '1'
- name: SL_BTMESH_CONFIG_MAX_PROV_BEARERS
  value: '3'
- name: SL_CLI_NUM_HISTORY_BYTES
  value: '0'
- condition:
  - psa_crypto
  name: SL_PSA_KEY_USER_SLOT_COUNT
  value: '0'
- name: SL_SIMPLE_BUTTON_ALLOW_LED_CONFLICT
  value: '1'
- name: SL_STACK_SIZE
  value: '0x1300'
ui_hints:
  highlight:
  - path: config/btconf/gatt_configuration.btconf
  - path: config/btmeshconf/dcd_config.btmeshconf
  - path: readme_xg22.md
    focus: true

